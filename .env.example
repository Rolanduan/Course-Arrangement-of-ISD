# 排课系统环境变量配置示例

# 数据库类型: sqlite | postgresql | mysql
DB_TYPE=postgresql

# PostgreSQL 连接字符串 (使用 PostgreSQL 时需要)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://scheduler_user:your_password@your-server.postgres.database.azure.com:5432/scheduler

# MySQL 配置 (使用 MySQL 时需要)
MYSQL_HOST=your-mysql-server.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_USER=scheduler_user@your-mysql-server
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=scheduler

# 或者使用 Azure Database for MySQL 的连接字符串
# MYSQL_SSL_CERT=/path/to/BaltimoreCyberTrustRoot.crt.pem

# 应用配置
NODE_ENV=production

# 可选：启用调试日志
DEBUG=scheduler:*
