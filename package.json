{
  "name": "cq-weiming-scheduler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc -b && vite build",
    "build:cloud": "tsc && vite build",
    "start": "tsx server/index.ts",
    "test": "tsx --test server/**/*.test.ts",
    "netlify": "netlify dev",
    "deploy": "netlify deploy --prod"
  },
  "dependencies": {
    "@netlify/functions": "^2.8.2",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.12.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "netlify-cli": "^17.38.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
